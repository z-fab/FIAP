# Chave da API do Google Gemini (obrigatória)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-key-here

# Chave da API do Tavily (necessária para o agente de pesquisa)
# Obtenha em: https://tavily.com (tier gratuito: 1.000 req/mês)
TAVILY_API_KEY=your-tavily-key-here

# Modelo do Gemini (opcional, padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
