# === Estagio 04 — Producao (Controles de Producao) ===

# API Key do Gemini (obrigatoria)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-api-key-aqui

# URL de conexao com o PostgreSQL
# Padrao configurado no docker-compose.yml — altere apenas se usar banco externo
# DATABASE_URL=postgresql://agent:agent@postgres:5432/agent_tasks

# URL do broker RabbitMQ para o Celery
# Padrao configurado no docker-compose.yml — altere apenas se usar RabbitMQ externo
# CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# Hostname do RabbitMQ (usado pelo health check)
# RABBITMQ_HOST=rabbitmq

# --- Controle de concorrencia ---
# Numero maximo de agentes rodando simultaneamente
# MAX_CONCURRENT_AGENTS=3
# Numero maximo de requisicoes na fila de espera do semaforo
# MAX_QUEUE_SIZE=10

# --- Timeouts (em segundos) ---
# Timeout total da requisicao HTTP
# REQUEST_TIMEOUT=120
# Timeout para a invocacao completa do agente
# AGENT_TIMEOUT=90
# Timeout por chamada individual de ferramenta
# TOOL_TIMEOUT=30

# --- Ambiente ---
# development = logs coloridos no console
# production  = logs JSON para ferramentas de observabilidade
# ENVIRONMENT=development
