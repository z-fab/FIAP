# === Estágio 03 — Async (RabbitMQ + Celery + PostgreSQL) ===

# API Key do Gemini (obrigatória)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-api-key-aqui

# URL de conexão com o PostgreSQL
# Padrão configurado no docker-compose.yml — altere apenas se usar banco externo
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent_tasks

# URL do broker RabbitMQ para o Celery
# Padrão configurado no docker-compose.yml — altere apenas se usar RabbitMQ externo
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
